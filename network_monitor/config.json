{
  "name": "Network Monitor",
  "version": "1.0.0",
  "slug": "network_monitor",
  "description": "Monitor your network devices and track IP changes with Telegram notifications",
  "url": "https://github.com/elbarto8383/network_manager",
  "startup": "service",
  "boot": "auto",
  "hassio_api": true,
  "homeassistant_api": true,
  "privileged": ["NET_ADMIN", "NET_RAW"],
  "arch": ["aarch64", "amd64", "armhf", "armv7"],
  "ports": {
    "5000/tcp": 5000
  },
  "ports_description": {
    "5000/tcp": "Network Monitor Web Interface"
  },
  "options": {
    "network_range": "192.168.1.0/24",
    "scan_interval_hours": 1,
    "offline_threshold_hours": 2,
    "telegram_enabled": false,
    "telegram_bot_token": "",
    "telegram_chat_id": "",
    "api_key": ""
  },
  "schema": {
    "network_range": "str",
    "scan_interval_hours": "int(1,24)",
    "offline_threshold_hours": "int(1,48)",
    "telegram_enabled": "bool",
    "telegram_bot_token": "str?",
    "telegram_chat_id": "str?",
    "api_key": "str"
  }
}
